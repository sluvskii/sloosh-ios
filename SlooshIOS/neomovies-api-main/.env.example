# MongoDB
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGO_DB_NAME=neomovies

# JWT
JWT_SECRET=your-super-secret-jwt-key

# Kinopoisk API
KPAPI_KEY=your-kinopoisk-api-key
KPAPI_BASE_URL=https://kinopoiskapiunofficial.tech/api

# Neo ID SSO
NEO_ID_URL=https://id.neomovies.ru
NEO_ID_API_KEY=your-neo-id-api-key
NEO_ID_SITE_ID=your-neo-id-site-id

# Player tokens
HDVB_TOKEN=your-hdvb-token
VIBIX_HOST=https://vibix.example.com
VIBIX_TOKEN=your-vibix-token
LUMEX_URL=https://lumex.example.com/embed
ALLOHA_TOKEN=your-alloha-token
COLLAPS_API_HOST=https://api.collaps.example.com
COLLAPS_TOKEN=your-collaps-token

# RedAPI (torrents)
REDAPI_BASE_URL=https://jac-red.ru

# Local server
LOCAL_SERVER_PORT=3000
